+++ Location: Firestore — 'cases' and 'personnel' collections publicly readable

# Update Firestore security rules

```javascript
// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ❌ BEFORE: allow read, write: if true;

    // ✅ AFTER: Require authentication + role checks
    match /cases/{caseId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'caseworker'];
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
```

